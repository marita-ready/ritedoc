    {
      "id": 1,
      "name": "Unauthorised Restrictive Practice",
      "description": "Physical guidance, restraint, seclusion, or restricting movement, communication, or access without documented authorisation in a Behaviour Support Plan.",
      "severity": "HIGH",
      "keywords": [
        "physically guided",
        "physical guidance",
        "restrained",
        "restraint",
        "held down",
        "held back",
        "seclusion",
        "secluded",
        "locked in",
        "locked room",
        "restricted movement",
        "restricted access",
        "prevented from leaving",
        "stopped from",
        "blocked exit",
        "grabbed",
        "forcibly",
        "forced",
        "refused to let",
        "would not allow",
        "restricted communication",
        "took phone",
        "removed device",
        "chemical restraint",
        "PRN for behaviour",
        "given medication to calm"
      ],
      "context_keywords": [
        "refused",
        "declined",
        "agitated",
        "aggressive",
        "distressed",
        "non-compliant",
        "uncooperative"
      ],
      "required_forms": [
        {
          "form_name": "Restrictive Practice Notification Form",
          "authority": "NDIS Quality and Safeguards Commission",
          "fields": [
            {"label": "Date", "auto_fill": "note_date", "required": true},
            {"label": "Participant", "auto_fill": "participant_name", "required": true},
            {"label": "Type of Practice", "auto_fill": null, "required": true},
            {"label": "Duration", "auto_fill": null, "required": true},
            {"label": "Authorisation Status", "auto_fill": null, "required": true},
            {"label": "Staff Identifier", "auto_fill": "support_worker", "required": true},
            {"label": "Description of Circumstances", "auto_fill": null, "required": true},
            {"label": "Less Restrictive Alternatives Attempted", "auto_fill": null, "required": true}
          ]
        },
        {
          "form_name": "Behaviour Support Plan Review Request",
          "authority": "Behaviour Support Practitioner",
          "fields": [
            {"label": "Date of Request", "auto_fill": "note_date", "required": true},
            {"label": "Participant", "auto_fill": "participant_name", "required": true},
            {"label": "Reason for Review", "auto_fill": null, "required": true},
            {"label": "Current BSP Reference Number", "auto_fill": null, "required": true},
            {"label": "Behaviour Specialist Assigned", "auto_fill": null, "required": true}
          ]
        }
      ]
    },
